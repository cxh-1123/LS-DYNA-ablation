# V6B LAMMPS ttm/mod Si laser ablation scout
# case: fluence_2p0_100ps
# Generated by scripts/build_v61_lammps_ttm_mod_ablation_scan.py

units           metal
dimension       3
boundary        p p p
atom_style      atomic

variable        alat equal 5.431000
lattice         diamond ${alat}
region          box block 0 8 0 8 0 60 units lattice
create_box      1 box
region          si block 0 8 0 8 0 24 units lattice
create_atoms    1 region si

mass            1 28.085500
pair_style      sw
pair_coeff      * * Si.sw Si

neighbor        2.0 bin
neigh_modify    every 5 delay 0 check yes

region          bottom block INF INF INF INF INF 8.000000 units box
region          bath block INF INF INF INF 8.000000 20.000000 units box
group           bottom region bottom
group           bath region bath
group           mobile subtract all bottom

compute         peatom all pe/atom
compute         keatom all ke/atom
compute         satom all stress/atom NULL

timestep        0.00025000
velocity        mobile create 300.0 4928459 mom yes rot yes dist gaussian
velocity        bottom set 0.0 0.0 0.0
fix             hold bottom setforce 0.0 0.0 0.0

min_style       cg
minimize        1.0e-8 1.0e-10 500 5000

fix             nve mobile nve
fix             bathfix bath langevin 300.0 300.0 0.1 827364 zero yes
thermo          1000
thermo_style    custom step time temp pe ke etotal press
run             8000
unfix           bathfix

# Real laser-source scout using LAMMPS fix ttm/mod.
fix             twotemp all ttm/mod 97531864 v61_fluence_2p0_100ps.ttm_mod 4 4 40 set 300.000 outfile 4000 Te_out

dump            atomdump all custom 4000 dump.v61_fluence_2p0_100ps.lammpstrj id type x y z vx vy vz c_keatom c_peatom c_satom[1] c_satom[2] c_satom[3] c_satom[4] c_satom[5] c_satom[6]
dump_modify     atomdump sort id
run             400000

write_data      final.v61_fluence_2p0_100ps.data

unfix           twotemp
unfix           nve
unfix           hold
